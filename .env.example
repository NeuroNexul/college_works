# This is an example of the .env file
# You should copy this file to .env and set the values as you need
# Run `cp .env.example .env` to create the .env file

# Application Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_DEBUG=True

# Docker Settings
CONTAINER_NAME=quiz-master

# Database Settings
DATABASE_NAME=quiz-master
DATABASE_USER=admin
DATABASE_PASSWORD=root
DATABASE_ROOT_PASSWORD=root
DATABASE_PORT=3306

# PHP My Admin
PHPMYADMIN_PORT=8080

